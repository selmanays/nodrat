# =============================================================================
# infra/.env.encrypted.example — sops + age yapı örneği (#38)
#
# Bu dosya GERÇEK bir encrypted secret değildir.
# `sops -e` ile üretilen bir dosyanın yaklaşık şeması/yapısı için referans.
#
# Gerçek üretim için adımlar:
#   1. Düz metin .env'i hazırla (kök dizin, .gitignore içinde)
#   2. age-keygen ile public/private çift üret (bkz. infra/sops-setup.md)
#   3. Public key'i infra/.sops.yaml içindeki `creation_rules.age` listesine ekle
#   4. `sops --encrypt --config infra/.sops.yaml .env > infra/.env.encrypted`
#   5. Üretilen dosyayı commit et — bu örnek dosyayı SİL veya yerine bırak.
#
# sops çıktısı tipik olarak şu yapıda olur (placeholder değerler):
# =============================================================================

ENVIRONMENT=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]
DATABASE_URL=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]
REDIS_URL=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]
API_SECRET_KEY=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]
JWT_SECRET=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]
FERNET_KEY=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]
NIM_API_KEY=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]
DEEPSEEK_API_KEY=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]
RESEND_API_KEY=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]
SENTRY_DSN=ENC[AES256_GCM,data:placeholderdata,iv:placeholderiv,tag:placeholdertag,type:str]

# sops "trailer" — gerçek encrypted dosyada metadata/key signing burada bulunur
sops_version=3.9.0
sops_age__list_0__map_recipient=age1exampleexampleexampleexampleexampleexampleexampleexampleexampleex
sops_lastmodified=2026-05-01T00:00:00Z
sops_mac=ENC[AES256_GCM,data:placeholdermac,iv:placeholderiv,tag:placeholdertag,type:str]
sops_unencrypted_suffix=_unencrypted
sops_encrypted_regex=^(.*)$
