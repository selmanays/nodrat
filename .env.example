# =============================================================================
# Nodrat — Environment Variables Template
# =============================================================================
# Bu dosya repo'ya commit edilir; gerçek değerler için .env (gitignore'da)
# kullanın. Production'da sops + age ile encrypted .env.sops kullanılır.
# Detay: docs/engineering/architecture.md §7
# =============================================================================

# -----------------------------------------------------------------------------
# Çalışma ortamı
# -----------------------------------------------------------------------------
ENVIRONMENT=development                    # development | staging | production
DEFAULT_LANGUAGE=tr
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16 + pgvector)
# -----------------------------------------------------------------------------
POSTGRES_DB=nodrat
POSTGRES_USER=nodrat
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://nodrat:change-me-in-production@postgres:5432/nodrat

# -----------------------------------------------------------------------------
# Redis (broker + cache)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change-me-redis
REDIS_URL=redis://:change-me-redis@redis:6379/0

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_IMAGES=nodrat-images
MINIO_BUCKET_SNAPSHOTS=nodrat-snapshots
MINIO_BUCKET_BACKUPS=nodrat-backups
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# API secrets
# -----------------------------------------------------------------------------
# openssl rand -hex 32 ile üret
API_SECRET_KEY=change-me-32-byte-hex-string
JWT_SECRET=change-me-jwt-secret
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# Fernet key for provider API key encryption at rest
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key

# -----------------------------------------------------------------------------
# LLM Provider API keys
# Detay: docs/strategy/unit-economics.md §4
# -----------------------------------------------------------------------------
# DeepSeek native API (#163 — primary chat provider)
DEEPSEEK_API_KEY=                          # sk-xxx (https://platform.deepseek.com)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
# Alternatif: deepseek-reasoner (R1 — reasoning-heavy task'lar için)
DEEPSEEK_CAMPAIGN_DISCOUNT=0.25
# 31 May 2026 kampanya bittiğinde 1.0'a çek

# NIM (DEPRECATED #163 — PR-C cleanup'da tamamen kaldırılacak)
# Local bge-m3 primary olduğu için NIM_API_KEY artık gerekmez
# NIM_API_KEY=
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Local embedding (#163 scaffold, #223 default'a değin defer)
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
USE_LOCAL_EMBEDDING=false                  # Default false — NIM ile DB embeddings uyumlu.
                                           # True'ya çekmeden önce migration task ile re-embed gerek (#223).

# Local rerank (#224 PR-9 MVP-1.5)
LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3
USE_LOCAL_RERANK=false                     # Default false — eval gate (NDCG@10 ≥ 0.90) sonrası flip.
                                           # Rerank runtime-only — DB state etkilenmez, migration gerek yok.

OPENROUTER_API_KEY=                        # Fallback LLM
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

ANTHROPIC_API_KEY=                         # Premium (Pro+ tier, Faz 2'de aktif)
OPENAI_API_KEY=                            # Son fallback (Faz 2+)

# Default provider routing
DEFAULT_LLM_PROVIDER=deepseek_v3
DEFAULT_EMBEDDING_PROVIDER=nim_bge_m3

# Provider monthly cost cap (USD) — R-FIN-01 mitigation
PROVIDER_MONTHLY_CAP_DEEPSEEK=200.00
PROVIDER_MONTHLY_CAP_ANTHROPIC=300.00
PROVIDER_MONTHLY_CAP_OPENROUTER=100.00

# -----------------------------------------------------------------------------
# Email (transactional) — #68
# -----------------------------------------------------------------------------
RESEND_API_KEY=
MAIL_FROM=hello@nodrat.com
MAIL_FROM_NAME=Nodrat

# Sender role-based addresses (no personal names)
RESEND_FROM_TRANSACTIONAL=no-reply@nodrat.com
RESEND_FROM_HELLO=hello@nodrat.com
RESEND_FROM_LEGAL=legal@nodrat.com
RESEND_FROM_DPO=dpo@nodrat.com
RESEND_REPLY_TO=support@nodrat.com

# Token TTL
EMAIL_VERIFY_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_HOURS=1

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
# Development:
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# Production override (#138 — email linkleri için):
# NEXT_PUBLIC_API_URL=https://nodrat.com/api
# NEXT_PUBLIC_APP_URL=https://nodrat.com
NEXT_PUBLIC_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Domain / TLS (production)
# -----------------------------------------------------------------------------
DOMAIN=nodrat.com
ADMIN_EMAIL=legal@nodrat.com               # Let's Encrypt + NodratBot UA contact

# -----------------------------------------------------------------------------
# Port mapping — VPS izolasyon (KRITIK)
# -----------------------------------------------------------------------------
# Bu VPS'te başka uygulamalar çalışıyorsa, Nodrat servislerinin portları
# çakışmamalı. Default değerler local dev için; production'da boş bırakıp
# sadece internal Docker network'te çalıştırabilirsiniz, ya da yüksek port
# numaraları kullanabilirsiniz.
#
# Production önerisi: Caddy 8080/8443'e bind eder, mevcut reverse proxy
# (nginx, vb.) public 80/443'ten Nodrat'a forward eder. Ya da Caddy
# kaldırılıp doğrudan FastAPI 8000'e mevcut proxy'den forward.

CADDY_HTTP_PORT=8080                       # Production: 80 yerine
CADDY_HTTPS_PORT=8443                      # Production: 443 yerine

# Sadece local dev için expose edilenler (production'da hepsi YORUM YAPILABILIR
# çünkü Docker internal network'ten erişim yeterli):
WEB_PORT=3000                              # Next.js dev server (sadece dev)
API_PORT=8000                              # FastAPI (sadece dev)
POSTGRES_PORT=5433                         # Default 5432 değil — VPS izolasyon
REDIS_PORT=6380                            # Default 6379 değil — VPS izolasyon
MINIO_API_PORT=9100                        # Default 9000 değil — VPS izolasyon
MINIO_CONSOLE_PORT=9101                    # Default 9001 değil — VPS izolasyon

# Container ve volume naming: tüm Nodrat resource'ları "nodrat-" prefix'li
COMPOSE_PROJECT_NAME=nodrat

# -----------------------------------------------------------------------------
# Object Storage — Contabo S3 (#217 MVP-1.5 PR-2)
# -----------------------------------------------------------------------------
# Region eu2 = Düsseldorf; eu1 = Nuremberg; ap-east = Singapore
S3_ENDPOINT_URL=https://eu2.contabostorage.com
S3_REGION=eu2
S3_BUCKET=nodrat-prod
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Backup (restic + Contabo S3)
# -----------------------------------------------------------------------------
# RESTIC_REPOSITORY backup.sh içinde S3_ENDPOINT_URL'den türetilir.
# RESTIC_PASSWORD restore için kritik — kaybedersek backup'lar erişilmez.
RESTIC_PASSWORD=change-me-restic-password

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
SENTRY_DSN=                                # Optional: production error tracking
SENTRY_ENVIRONMENT=development
SLACK_WEBHOOK_URL=                         # Critical alarms
